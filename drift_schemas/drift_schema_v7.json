  "fixed_sql": [
    {
      "name": "charters",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"charters\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"title\" TEXT NOT NULL, \"date_from\" INTEGER NOT NULL, \"date_to\" INTEGER NOT NULL, \"vessel_name\" TEXT NULL, \"vessel_type\" TEXT NULL, \"home_port\" TEXT NULL, \"skipper_name\" TEXT NULL, \"crew_names\" TEXT NULL, \"notes\" TEXT NULL, \"safety_briefing_done\" INTEGER NOT NULL DEFAULT 0 CHECK (\"safety_briefing_done\" IN (0, 1)), \"check_in_done\" INTEGER NOT NULL DEFAULT 0 CHECK (\"check_in_done\" IN (0, 1)), \"check_out_done\" INTEGER NOT NULL DEFAULT 0 CHECK (\"check_out_done\" IN (0, 1)), \"created_at\" INTEGER NOT NULL, \"remote_id\" TEXT NULL, \"synced_at\" INTEGER NULL, \"mmsi\" TEXT NULL, \"callsign\" TEXT NULL, \"vessel_length_m\" REAL NULL, \"vessel_beam_m\" REAL NULL, \"vessel_draft_m\" REAL NULL, \"pdf_revision\" INTEGER NOT NULL DEFAULT 0);"
        }
      ]
    },
    {
      "name": "day_logs",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"day_logs\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"charter_id\" INTEGER NOT NULL REFERENCES charters (id), \"date\" INTEGER NOT NULL, \"port_from\" TEXT NULL, \"port_to\" TEXT NULL, \"vessel_for_day\" TEXT NULL, \"distance_nm\" REAL NOT NULL DEFAULT 0.0, \"beaufort_morning\" INTEGER NULL, \"beaufort_noon\" INTEGER NULL, \"beaufort_evening\" INTEGER NULL, \"sea_state\" TEXT NULL, \"wave_height_m\" REAL NULL, \"wind_direction\" TEXT NULL, \"air_temp_c\" REAL NULL, \"water_temp_c\" REAL NULL, \"session_id\" TEXT NULL, \"skipper_note\" TEXT NULL, \"is_complete\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_complete\" IN (0, 1)));"
        }
      ]
    },
    {
      "name": "logbook_entries",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"logbook_entries\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"day_log_id\" INTEGER NULL REFERENCES day_logs (id), \"session_id\" TEXT NULL, \"timestamp\" INTEGER NOT NULL, \"latitude\" REAL NULL, \"longitude\" REAL NULL, \"sog\" REAL NULL, \"cog\" REAL NULL, \"heading\" REAL NULL, \"wind_speed\" REAL NULL, \"wind_direction\" REAL NULL, \"wave_height\" REAL NULL, \"air_pressure\" REAL NULL, \"air_temp\" REAL NULL, \"water_temp\" REAL NULL, \"engine_hours\" REAL NULL, \"fuel_consumed\" REAL NULL, \"skipper_name\" TEXT NULL, \"crew_names\" TEXT NULL, \"skipper_note\" TEXT NULL, \"is_auto_entry\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_auto_entry\" IN (0, 1)), \"weather_condition\" TEXT NULL, \"photo_path\" TEXT NULL);"
        }
      ]
    },
    {
      "name": "track_points",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"track_points\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"session_id\" TEXT NULL, \"timestamp\" INTEGER NOT NULL, \"latitude\" REAL NOT NULL, \"longitude\" REAL NOT NULL, \"altitude\" REAL NULL, \"speed\" REAL NULL, \"course\" REAL NULL, \"accuracy\" REAL NULL);"
        }
      ]
    },
    {
      "name": "sailing_sessions",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"sailing_sessions\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"session_id\" TEXT NOT NULL UNIQUE, \"day_log_id\" INTEGER NULL REFERENCES day_logs (id), \"start_time\" INTEGER NOT NULL, \"end_time\" INTEGER NULL, \"name\" TEXT NULL, \"total_distance_nm\" REAL NOT NULL DEFAULT 0.0, \"max_speed_knots\" REAL NOT NULL DEFAULT 0.0, \"avg_speed_knots\" REAL NOT NULL DEFAULT 0.0, \"is_active\" INTEGER NOT NULL DEFAULT 1 CHECK (\"is_active\" IN (0, 1)));"
        }
      ]
    },
    {
      "name": "waypoints",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"waypoints\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL, \"latitude\" REAL NOT NULL, \"longitude\" REAL NOT NULL, \"description\" TEXT NULL, \"type\" TEXT NULL, \"created_at\" INTEGER NOT NULL, \"is_favorite\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_favorite\" IN (0, 1)));"
        }
      ]
    },
    {
      "name": "weather_snapshots",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"weather_snapshots\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"latitude\" REAL NOT NULL, \"longitude\" REAL NOT NULL, \"forecast_time\" INTEGER NOT NULL, \"downloaded_at\" INTEGER NOT NULL, \"wind_speed\" REAL NOT NULL, \"wind_direction\" REAL NOT NULL, \"wave_height\" REAL NULL, \"wave_period\" REAL NULL, \"air_pressure\" REAL NULL, \"air_temp\" REAL NULL, \"water_temp\" REAL NULL, \"cloud_cover\" REAL NULL, \"weather_code\" INTEGER NULL, \"precipitation_probability\" INTEGER NULL, \"precipitation\" REAL NULL);"
        }
      ]
    },
    {
      "name": "crew_signatures",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"crew_signatures\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"charter_id\" INTEGER NOT NULL REFERENCES charters (id), \"crew_name\" TEXT NOT NULL, \"role\" TEXT NOT NULL DEFAULT 'crew', \"signature_path\" TEXT NULL, \"signed_at\" INTEGER NULL);"
        }
      ]
    }
